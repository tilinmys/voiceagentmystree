LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_LANGUAGE_CODE=en-IN
SARVAM_SPEAKER=ishita

# 60db.ai experimental Indian female TTS
SIXTY_DB_API_KEY=your_60db_api_key
USE_60DB_TTS=false
SIXTY_DB_TTS_URL=wss://api.60db.ai/ws/tts
SIXTY_DB_VOICE_ID=fbb75ed2-975a-40c7-9e06-38e30524a9a1
SIXTY_DB_VOICE_NAME=Zara
SIXTY_DB_TTS_SAMPLE_RATE=24000
SIXTY_DB_TTS_SPEED=1.04
SIXTY_DB_TTS_STABILITY=45
SIXTY_DB_TTS_SIMILARITY=78
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_primary_groq_api_key
GROQ_API_KEYS=your_primary_groq_api_key,your_secondary_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLM_MODEL=openai/gpt-oss-20b
LLM_MAX_COMPLETION_TOKENS=60
# Verified empirically on qwen/qwen3-32b (2026-07-13, 5 runs per setting,
# real clinic prompt, top_p=0.9): 0.25 and 0.4 produce near-identical stable
# replies (pairwise similarity 0.82-0.91); 0.7 starts drifting. Anything in
# the 0.25-0.4 band is fine - the tight persona prompt does most of the work.
LLM_TEMPERATURE=0.3
# Nucleus sampling cap - keeps phrasing in the most likely band so the TTS
# prosody (and the persona) stays consistent turn to turn.
LLM_TOP_P=0.9
GOOGLE_API_KEY=your_google_or_gemini_api_key
GEMINI_LLM_MODEL=gemini-2.5-flash
# Separate key for Gemini TTS (gemini_wrappers.py) - can be the same value as
# GOOGLE_API_KEY if your key has both Generative Language API access enabled.
GEMINI_API_KEY=your_gemini_api_key
ASSEMBLYAI_API_KEY=your_assemblyai_api_key
ASSEMBLYAI_STT_MODEL=universal-3-5-pro
STT_PRIMARY=deepgram
ASSEMBLYAI_LANGUAGE_CODE=en-IN
# Maximum turn silence duration in ms (default 800)
ASSEMBLYAI_MAX_TURN_SILENCE=650
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-IN
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_TTS_MODEL=sonic-3
CARTESIA_LANGUAGE=en
ELEVENLABS_API_KEY=your_elevenlabs_api_key
SMALLEST_API_KEY=your_smallest_ai_api_key
RUMIK_API_KEY=your_rumik_api_key
SMALLEST_SPEED=1.05
SMALLEST_SPEED_GREETING=0.88
SARVAM_PACE_GREETING=0.9

CLINIC_NAME=MyStree Clinic
STT_KEY_TERMS=MyStree Clinic,MyStree,Angel,Anjali,Anju,Priya,Divya,Deepa,Deepti,Ritu,Neha,Meera,Anita,Rajesh,Sunita,Surbhi,Smitha,Swathi,Chaitra,Nivetha,Indiranagar,gynecologist,gynaecologist,pregnancy,PCOS,Kannada,Hinglish,amma,akka,OPD
CLINIC_TIMEZONE=Asia/Kolkata
OPENAI_LLM_MODEL=gpt-4o-mini
LLM_MODEL=gpt-4o-mini
LLM_MAX_COMPLETION_TOKENS=60
SQLITE_DB_PATH=data/mystree_demo.sqlite3
PREEMPTIVE_GENERATION=true
PREEMPTIVE_TTS=true
ENABLE_MULTILINGUAL_TURN_DETECTOR=true
SARVAM_PACE=1.05
SARVAM_MIN_BUFFER_SIZE=35
SARVAM_MAX_CHUNK_LENGTH=160
# WebSocket open timeout before falling back to the next TTS provider
SARVAM_TTS_TIMEOUT=5.0
# After final flush, silence from the server for this long = segment complete
SARVAM_TTS_IDLE_TIMEOUT=1.0
# How often the in-memory slot cache re-reads open slots from the database
SLOT_CACHE_REFRESH_SECONDS=10
# "vad" (default): commit the user's turn at Silero end-of-speech once the
# final transcript is in. "stt": additionally wait for the STT provider's own
# end-of-turn signal - with Deepgram primary that signal trailed its final
# transcripts by ~500-600ms, pushing EOU p50 to ~1.1s. Set to stt to revert.
VOICE_TURN_DETECTION_MODE=vad
# 0.25-0.45s is the natural endpointing band; below ~0.1s the agent commits to
# turns the caller hasn't finished, producing cancelled generations. In vad
# mode this is the whole endpointing wait, so keep it >= 0.3.
MIN_ENDPOINTING_DELAY=0.35
MAX_ENDPOINTING_DELAY=1.2
# Filler audio ("one second, pulling that up...") only plays if a tool is
# still running after this many ms. DB tools finish in 7-15ms and must not
# trigger filler that takes longer to say than the lookup itself.
VOICE_FILLER_THRESHOLD_MS=900
# Static FAQ cache (hours/location/fees/Sunday-closed) - intercepts these
# before the LLM using OpenAI text-embedding-3-small, warmed once at worker
# prewarm. Requires OPENAI_API_KEY. See faq_cache.py.
VOICE_FAQ_CACHE_ENABLED=true
# Adaptive VAD: endpointing min_delay toggles per turn based on what the
# agent just asked - fast for closed questions (yes/no, slots), slow when
# the caller needs to think or spell (names, concerns). Fragment recovery
# extends the window one turn after a cut-off sentence. Perceived wait ~=
# VAD silence (0.2s) + min_delay. FAST reuses MIN_ENDPOINTING_DELAY.
VOICE_ADAPTIVE_VAD_ENABLED=true
VAD_ENDPOINT_SLOW_S=1.0
VAD_ENDPOINT_FRAGMENT_S=1.3
# Deterministic safety guardrails (guardrails.py): medical-advice/emergency/
# self-harm/jailbreak turns are answered with fixed approved scripts and
# never reach the LLM; generated text is scanned for drug/dosage phrasing
# before TTS. Independent of VOICE_FAST_PATH_ENABLED on purpose - safety
# must not turn off with a latency toggle. Leave on in production.
VOICE_GUARDRAILS_ENABLED=true
# Empirically measured (2026-07-14, see faq_cache.py) - NOT 0.85, which was
# unreachable even for unambiguous true matches at this embedding dimension.
FAQ_CACHE_SIMILARITY_THRESHOLD=0.65
# end_call waits (bounded) for all queued speech to finish playing before
# deleting the room, so the goodbye is never cut off mid-word.
END_CALL_MAX_WAIT_SECONDS=8.0
DB_TOOL_TIMEOUT_SECONDS=2.0
ENABLE_LINE_LIVE_CHECK=true
LINE_LIVE_CHECK_SECONDS=14.0
LINE_LIVE_CHECK_COOLDOWN_SECONDS=30.0

# --- Latency feature flags (all reversible kill-switches, default true) ---
# Skip the LLM for unambiguous state-free turns (repeat requests, bare phone
# number echo-confirmation). See agent.fast_path_reply.
VOICE_FAST_PATH_ENABLED=true
# After a successful booking/reschedule/cancel, refresh the slot suggestion
# cache in the background instead of blocking the spoken confirmation.
VOICE_ASYNC_SLOT_REFRESH_ENABLED=true
# Use Smallest.ai's SSE /stream endpoint (first audio ~260-280ms warm) instead
# of the buffered /get_speech endpoint (~545-657ms warm).
VOICE_INCREMENTAL_TTS_ENABLED=true
# Bounded queue between the call path and the pipeline-log writer thread.
PIPELINE_LOG_QUEUE_MAX=2000
LLM_FALLBACK_ATTEMPT_TIMEOUT=2.0
PREFETCH_TTL_SECONDS=90
PREFETCH_SLOT_REFRESH_MIN_SECONDS=60
# Benchmarked 2026-07-13 with the real clinic system prompt, streaming, 8 runs
# each (scripts/llm_benchmark.py): groq/qwen3-32b TTFT p50 270-358ms vs
# openai/gpt-4o-mini 1000-1182ms vs gemini-2.5-flash 1451-1516ms (also hit
# 429 quota on the free tier mid-run). Groq is ~3.5x faster and is now
# primary in production. Set false to fall back to OpenAI-primary if the
# Groq account's TPM limit becomes a problem under real call volume - the
# FallbackAdapter already covers transient 429s either way.
GROQ_PRIMARY=true
STT_FALLBACK_ATTEMPT_TIMEOUT=4
# AssemblyAI is the fallback (not primary) with STT_PRIMARY=deepgram, so
# "balanced" costs nothing on a normal call and improves accuracy for the
# rare turns that do fail over to it.
ASSEMBLYAI_MODE=balanced
# Biases STT recognition toward ~120 common Indian first names + clinic/
# doctor terms via Deepgram/AssemblyAI keyterm prompting, so a caller's own
# name is less likely to be mis-heard as an unrelated English word. See
# agent.COMMON_INDIAN_NAMES.
STT_BIAS_COMMON_NAMES=true
PREFETCH_MAX_CONCURRENCY=1
PREFETCH_MAX_ENTRIES=12


# Keep local Kitten disabled in live calls; it can cold-start for 7-80s on Windows.
KITTEN_TTS_ENABLED=false
PREWARM_KITTEN_TTS=false
