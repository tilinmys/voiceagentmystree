LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_LANGUAGE_CODE=en-IN
SARVAM_SPEAKER=ishita

# 60db.ai experimental Indian female TTS
SIXTY_DB_API_KEY=your_60db_api_key
USE_60DB_TTS=false
SIXTY_DB_TTS_URL=wss://api.60db.ai/ws/tts
SIXTY_DB_VOICE_ID=fbb75ed2-975a-40c7-9e06-38e30524a9a1
SIXTY_DB_VOICE_NAME=Zara
SIXTY_DB_TTS_SAMPLE_RATE=24000
SIXTY_DB_TTS_SPEED=1.04
SIXTY_DB_TTS_STABILITY=45
SIXTY_DB_TTS_SIMILARITY=78
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_primary_groq_api_key
GROQ_API_KEYS=your_primary_groq_api_key,your_secondary_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLM_MODEL=llama-3.1-8b-instant
GOOGLE_API_KEY=your_google_or_gemini_api_key
GEMINI_LLM_MODEL=gemini-2.5-flash
# Separate key for Gemini TTS (gemini_wrappers.py) - can be the same value as
# GOOGLE_API_KEY if your key has both Generative Language API access enabled.
GEMINI_API_KEY=your_gemini_api_key
ASSEMBLYAI_API_KEY=your_assemblyai_api_key
ASSEMBLYAI_STT_MODEL=universal-3-5-pro
ASSEMBLYAI_LANGUAGE_CODE=en-IN
# Maximum turn silence duration in ms (default 800)
ASSEMBLYAI_MAX_TURN_SILENCE=650
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-IN
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_TTS_MODEL=sonic-3
CARTESIA_LANGUAGE=en
ELEVENLABS_API_KEY=your_elevenlabs_api_key
SMALLEST_API_KEY=your_smallest_ai_api_key
RUMIK_API_KEY=your_rumik_api_key
SMALLEST_SPEED=1.05
SMALLEST_SPEED_GREETING=0.88
SARVAM_PACE_GREETING=0.9

CLINIC_NAME=MyStree Clinic
STT_KEY_TERMS=MyStree Clinic,MyStree,Angel,Anjali,Anju,Priya,Divya,Deepa,Deepti,Ritu,Neha,Meera,Anita,Rajesh,Sunita,Surbhi,Smitha,Swathi,Chaitra,Nivetha,Indiranagar,gynecologist,gynaecologist,pregnancy,PCOS,Kannada,Hinglish,amma,akka,OPD
CLINIC_TIMEZONE=Asia/Kolkata
OPENAI_LLM_MODEL=gpt-4o-mini
LLM_MODEL=gpt-4o-mini
LLM_MAX_COMPLETION_TOKENS=60
SQLITE_DB_PATH=data/mystree_demo.sqlite3
PREEMPTIVE_GENERATION=true
PREEMPTIVE_TTS=true
ENABLE_MULTILINGUAL_TURN_DETECTOR=true
SARVAM_PACE=1.05
SARVAM_MIN_BUFFER_SIZE=35
SARVAM_MAX_CHUNK_LENGTH=160
# WebSocket open timeout before falling back to the next TTS provider
SARVAM_TTS_TIMEOUT=5.0
# After final flush, silence from the server for this long = segment complete
SARVAM_TTS_IDLE_TIMEOUT=1.0
# How often the in-memory slot cache re-reads open slots from the database
SLOT_CACHE_REFRESH_SECONDS=10
MIN_ENDPOINTING_DELAY=0.05
MAX_ENDPOINTING_DELAY=1.2
DB_TOOL_TIMEOUT_SECONDS=2.0
ENABLE_LINE_LIVE_CHECK=true
LINE_LIVE_CHECK_SECONDS=7.0
LINE_LIVE_CHECK_COOLDOWN_SECONDS=25.0
LLM_FALLBACK_ATTEMPT_TIMEOUT=2.0
PREFETCH_TTL_SECONDS=90
PREFETCH_SLOT_REFRESH_MIN_SECONDS=60
# Keep false for production unless Groq account tier can handle the full clinic prompt without 429 TPM limits.
GROQ_PRIMARY=false
STT_FALLBACK_ATTEMPT_TIMEOUT=4
ASSEMBLYAI_MODE=min_latency
PREFETCH_MAX_CONCURRENCY=1
PREFETCH_MAX_ENTRIES=12


# Keep local Kitten disabled in live calls; it can cold-start for 7-80s on Windows.
KITTEN_TTS_ENABLED=false
PREWARM_KITTEN_TTS=false
